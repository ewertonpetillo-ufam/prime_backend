# MinIO — URL que o Nest usa para S3 (get/put/stream). Deve ser alcançável DE ONDE O NODE RODA.
#
# Dev (Nest na sua máquina + túnel SSH; no servidor o MinIO publica 127.0.0.1:9000):
#   ssh -N -L 9000:127.0.0.1:9000 -L 9001:127.0.0.1:9001 USUARIO@SERVIDOR
MINIO_ENDPOINT=http://127.0.0.1:9000
# Links presignados no navegador: mesmo host que o browser alcança (túnel = localhost).
MINIO_PUBLIC_BASE_URL=http://127.0.0.1:9000
#
# Produção (Nest no Docker, rede "frontend" com o container nomeado "minio"):
# MINIO_ENDPOINT=http://minio:9000
# MINIO_PUBLIC_BASE_URL=https://prime.icomp.ufam.edu.br/minio
MINIO_ACCESS_KEY=prime
MINIO_SECRET_KEY="Prime@2026"
MINIO_BUCKET=prime-coleta
MINIO_REGION=us-east-1
MINIO_FORCE_PATH_STYLE=true

# Runtime / uploads (produção)
NODE_OPTIONS=--max-old-space-size=2048
UPLOAD_MAX_FILE_SIZE_BYTES=314572800