# Application
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# Database
DB_HOST=prime-postgres
DB_PORT=5432
DB_USERNAME=prime_admin
DB_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
DB_DATABASE=prime_db

# JWT Authentication
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_SECRET_KEY_AT_LEAST_32_CHARACTERS
JWT_EXPIRATION=24h

# Client Credentials for JWT
# Client 1: Mobile Collection App
CLIENT_1_ID=collection_app
CLIENT_1_SECRET=CHANGE_THIS_CLIENT_1_SECRET

# Client 2: Web Frontend
CLIENT_2_ID=web_frontend
CLIENT_2_SECRET=CHANGE_THIS_CLIENT_2_SECRET

# HMAC for CPF Anonymization
HMAC_SECRET=CHANGE_THIS_TO_A_STRONG_HMAC_SECRET_KEY

# Swagger Documentation
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=CHANGE_THIS_SWAGGER_PASSWORD

# CORS
CORS_ORIGIN=http://localhost:3000

# MinIO (S3-compatible) — relatórios PDF (bucket prime-coleta: pastas baiobit, delsys, polysomnograph)
#
# Portas no container: 9000 = API S3 | 9001 = console web
#
# --- Produção (Nest no Docker, mesma rede Docker que o MinIO, ex. rede "frontend") ---
# No host, o MinIO costuma estar mapeado só em 127.0.0.1:9000 — NÃO use IP público:9000 no backend,
# porque nada escuta na interface pública nessa porta.
# O backend (prime-backend) deve usar o DNS interno do serviço do compose do MinIO:
#   MINIO_ENDPOINT=http://minio:9000
# URL pública para assinatura de links presignados (o navegador do usuário precisa alcançar):
#   MINIO_PUBLIC_BASE_URL=https://prime.icomp.ufam.edu.br/minio
# (Se presign falhar com StripPrefix do Traefik, use subdomínio dedicado à API S3.)
#
# O docker-compose do backend define padrão MINIO_ENDPOINT=http://minio:9000 se a variável estiver vazia.
#
# --- Dev (Nest na sua máquina + MinIO no servidor, só em 127.0.0.1:9000 no host) ---
# Túnel SSH (API + console; mantenha -N em um terminal):
#   ssh -N -L 9000:127.0.0.1:9000 -L 9001:127.0.0.1:9001 USUARIO@10.208.201.80
# Nest na máquina local:
#   MINIO_ENDPOINT=http://127.0.0.1:9000
#   MINIO_PUBLIC_BASE_URL=http://127.0.0.1:9000
# ServerAliveInterval evita o SSH derrubar o canal em upload longo (ECONNRESET):
#   ssh -N -o ServerAliveInterval=30 -o ServerAliveCountMax=6 -L 9000:127.0.0.1:9000 -L 9001:127.0.0.1:9001 USUARIO@HOST
#
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_PUBLIC_BASE_URL=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=prime-coleta
MINIO_REGION=us-east-1
MINIO_FORCE_PATH_STYLE=true
