# Application
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# Database
DB_HOST=prime-postgres
DB_PORT=5432
DB_USERNAME=prime_admin
DB_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
DB_DATABASE=prime_db

# JWT Authentication
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_SECRET_KEY_AT_LEAST_32_CHARACTERS
JWT_EXPIRATION=24h

# Client Credentials for JWT
# Client 1: Mobile Collection App
CLIENT_1_ID=collection_app
CLIENT_1_SECRET=CHANGE_THIS_CLIENT_1_SECRET

# Client 2: Web Frontend
CLIENT_2_ID=web_frontend
CLIENT_2_SECRET=CHANGE_THIS_CLIENT_2_SECRET

# HMAC for CPF Anonymization
HMAC_SECRET=CHANGE_THIS_TO_A_STRONG_HMAC_SECRET_KEY

# Swagger Documentation
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=CHANGE_THIS_SWAGGER_PASSWORD

# CORS
CORS_ORIGIN=http://localhost:3000

# Email SMTP (para envio de links de redefinição de senha)
# Configure com o email institucional (ex.: usuario@icomp.ufam.edu.br) usando senha de app do Google.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=SEU_EMAIL_INSTITUCIONAL@icomp.ufam.edu.br
SMTP_PASS=SENHA_DE_APP_DO_GOOGLE
SMTP_SECURE=false

# URL base do frontend usada para montar o link de redefinição de senha
FRONTEND_BASE_URL=http://localhost:3000

# Tempo de expiração do token de redefinição de senha (em minutos)
RESET_PASSWORD_EXP_MINUTES=60
