# Application
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# Database
DB_HOST=prime-postgres
DB_PORT=5432
DB_USERNAME=prime_admin
DB_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
DB_DATABASE=prime_db

# JWT Authentication
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_SECRET_KEY_AT_LEAST_32_CHARACTERS
JWT_EXPIRATION=24h

# Client Credentials for JWT
# Client 1: Mobile Collection App
CLIENT_1_ID=collection_app
CLIENT_1_SECRET=CHANGE_THIS_CLIENT_1_SECRET

# Client 2: Web Frontend
CLIENT_2_ID=web_frontend
CLIENT_2_SECRET=CHANGE_THIS_CLIENT_2_SECRET

# HMAC for CPF Anonymization
HMAC_SECRET=CHANGE_THIS_TO_A_STRONG_HMAC_SECRET_KEY

# Swagger Documentation
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=CHANGE_THIS_SWAGGER_PASSWORD

# CORS
CORS_ORIGIN=http://localhost:3000

# MinIO (S3-compatible) — relatórios PDF (bucket prime-coleta: pastas baiobit, delsys, polysomnograph)
#
# Portas no container: 9000 = API S3 | 9001 = console web
#
# --- Produção (Nest no Docker, mesma rede que o stack do MinIO) ---
# Use o hostname do serviço no compose (nome do serviço = DNS interno do Docker).
# MINIO_ENDPOINT=http://minio:9000
# MINIO_PUBLIC_BASE_URL=https://prime.icomp.ufam.edu.br/minio
# (URL pública para links presignados no navegador; se o Traefik usar StripPrefix /minio e as URLs
#  presignadas falharem em assinatura, exponha a API S3 em subdomínio sem prefix de path.)
#
# --- Dev (Nest na sua máquina + MinIO no servidor) ---
# Publique a API S3 só em localhost no servidor (ex. no compose do MinIO: "127.0.0.1:9000:9000").
# No notebook, mantenha o túnel aberto e use localhost nas duas variáveis:
# MINIO_ENDPOINT=http://127.0.0.1:9000
# MINIO_PUBLIC_BASE_URL=http://127.0.0.1:9000
#
# Comando do túnel (troque USUARIO; no servidor algo deve escutar em 127.0.0.1:9000).
# ServerAliveInterval evita o SSH derrubar o canal em upload longo (ECONNRESET):
#   ssh -N -o ServerAliveInterval=30 -o ServerAliveCountMax=6 -L 9000:127.0.0.1:9000 USUARIO@prime.icomp.ufam.edu.br
# Em outro terminal: rode o Nest. Ctrl+C no ssh encerra o túnel.
#
MINIO_ENDPOINT=http://127.0.0.1:9099
MINIO_PUBLIC_BASE_URL=http://127.0.0.1:9099
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=prime-coleta
MINIO_REGION=us-east-1
MINIO_FORCE_PATH_STYLE=true
